generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  user
}

enum ProjectStatus {
  planerat
  bokat
  pagaende
  pausat
  klart
  fakturerat
  installt
}

enum ResourceStatus {
  aktiv
  service
  ur_drift
}

enum NotificationTarget {
  none
  assigned
  all
}

enum RecurrenceFrequency {
  daily
  weekly
  monthly
}

enum AllowanceType {
  nej
  halv
  hel
}

enum TimeReportType {
  arbete
  sjuk
  ledig
  vab
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String?        @unique
  passwordHash String
  role         Role           @default(user)
  active       Boolean        @default(true)
  employeeId   String?
  employee     Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  auditLogs    AuditLog[]
  notifications Notification[]
  projectFiles ProjectFile[]
  createdTimeReports TimeReport[] @relation("TimeReportCreatedBy")
  createdDiaryEntries DiaryEntry[] @relation("DiaryEntryCreatedBy")

  @@index([role])
}

model Team {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  employees   Employee[]
  projects    Project[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id          String            @id @default(cuid())
  name        String
  personalNumber String?
  address     String?
  postalCode  String?
  city        String?
  phone       String?
  email       String?
  title       String
  skills      String[]          @default([])
  apvDate     DateTime?
  apvExpiryDate DateTime?
  id06Date    DateTime?
  id06Number  String?
  id06ExpiryDate DateTime?
  otherCompetence String?
  otherCompetenceDate DateTime?
  otherCompetenceExpiryDate DateTime?
  teamId      String?
  team        Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  users       User[]
  projects    ProjectEmployee[]
  timeReports TimeReport[]
  diaryEntries DiaryEntry[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([teamId])
}

model Machine {
  id        String           @id @default(cuid())
  name      String
  type      String
  status    ResourceStatus   @default(aktiv)
  projects  ProjectMachine[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Vehicle {
  id                 String           @id @default(cuid())
  name               String
  registrationNumber String           @unique
  status             ResourceStatus   @default(aktiv)
  projects           ProjectVehicle[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Project {
  id                  String            @id @default(cuid())
  name                String
  projectNumber       String            @unique
  customerName        String
  address             String
  city                String
  contactPerson       String?
  phone               String?
  startDate           DateTime
  endDate             DateTime
  startTime           String?
  endTime             String?
  allDay              Boolean           @default(true)
  status              ProjectStatus     @default(planerat)
  color               String            @default("#00af41")
  internalNote        String?
  externalDescription String?
  teamId              String?
  team                Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  employees           ProjectEmployee[]
  machines            ProjectMachine[]
  vehicles            ProjectVehicle[]
  files               ProjectFile[]
  recurringEvents     RecurringEvent[]
  notifications       Notification[]
  timeReports         TimeReport[]
  diaryEntries        DiaryEntry[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([status])
  @@index([startDate, endDate])
  @@index([city])
  @@index([teamId])
}

model ProjectEmployee {
  projectId  String
  employeeId String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([projectId, employeeId])
}

model ProjectMachine {
  projectId String
  machineId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  machine   Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@id([projectId, machineId])
}

model ProjectVehicle {
  projectId String
  vehicleId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([projectId, vehicleId])
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName    String
  originalName String
  mimeType    String
  size        Int
  storageKey  String
  uploadedById String?
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  read      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model RecurringEvent {
  id          String              @id @default(cuid())
  projectId   String?
  project     Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  frequency   RecurrenceFrequency
  interval    Int                 @default(1)
  startsOn    DateTime
  endsOn      DateTime?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String
  entityId  String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model TimeReport {
  id                 String        @id @default(cuid())
  employeeId         String
  employee           Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type               TimeReportType @default(arbete)
  date               DateTime
  hours              Float
  travelWithinHours  Float         @default(0)
  travelOutsideHours Float         @default(0)
  allowance          AllowanceType @default(nej)
  notes              String
  createdByUserId    String?
  createdByUser      User?         @relation("TimeReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([employeeId, date])
  @@index([projectId, date])
}

model DiaryEntry {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date            DateTime
  happenedToday   String
  completedToday  String
  extraWork       String?
  createdByUserId String?
  createdByUser   User?    @relation("DiaryEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId, date])
  @@index([projectId, date])
}
